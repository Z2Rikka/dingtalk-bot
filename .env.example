# ========================================
# 钉钉文档收集机器人 - 环境变量配置
# ========================================
# 复制此文件为 .env 并填写实际值
# 
# 获取钉钉凭证：https://open.dingtalk.com/
# 1. 创建自建应用
# 2. 获取 AppKey、AppSecret、AgentId
# 3. 配置消息回调地址
# ========================================

# ============ 机器人配置 (必填) ============
# 在钉钉开放平台 - 凭证与基础信息
BOT_APP_KEY=你的AppKey

# 在钉钉开放平台 - 凭证与基础信息
BOT_APP_SECRET=你的AppSecret

# 在钉钉开放平台 - 应用详情页
BOT_AGENT_ID=你的AgentId

# 机器人名称 (可选)
BOT_NAME=文档收集助手

# 消息接收端口 (可选，默认 3000)
BOT_PORT=3000


# ============ 存储配置 (可选) ============
# 文件存储根目录
STORAGE_BASE_DIR=./received_documents

# 文件名最大长度限制
STORAGE_MAX_FILENAME_LENGTH=200


# ============ 消息配置 (可选) ============
# 是否自动回复确认 (true/false)
MESSAGE_AUTO_REPLY=true

# 是否监听群消息 (true/false)
MESSAGE_LISTEN_GROUPS=true

# 是否监听私聊 (true/false)
MESSAGE_LISTEN_PRIVATE=true

# 允许接收的群ID (多个用逗号分隔，留空则监听所有群)
# 示例: xxx1,xxx2,xxx3
MESSAGE_ALLOWED_GROUP_IDS=


# ============ 日志配置 (可选) ============
# 是否启用日志 (true/false)
LOG_ENABLED=true

# 日志文件路径
LOG_FILE=./download_log.json

# 日志保留最大条数
LOG_MAX_ENTRIES=1000
